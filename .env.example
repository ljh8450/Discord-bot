# 채널별 Discord 웹훅
DISCORD_JOBS_WEBHOOK_URL=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
DISCORD_HACKATHONS_WEBHOOK_URL=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
DISCORD_INSIGHTS_WEBHOOK_URL=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
# GitHub Actions provides GITHUB_TOKEN automatically. Local runs need a token with models permission.
GITHUB_MODELS_MODEL=openai/gpt-4o-mini
DISCORD_ACTIVITIES_WEBHOOK_URL=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
DISCORD_EDUCATION_WEBHOOK_URL=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
DISCORD_OPERATIONS_WEBHOOK_URL=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN

# 현재 단일 opportunities 라우터와의 임시 호환용
DISCORD_OPPORTUNITIES_WEBHOOK_URL=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN

# 선택 사항: 행동 피드백 수신 endpoint
FEEDBACK_BASE_URL=

# 발송 직전 원문 URL 확인을 끄려면 false
RADAR_VERIFY_URLS=true

# 한 실행에서 Discord로 보내는 최대 알림 수
RADAR_MAX_NOTIFICATIONS_PER_RUN=10
SARAMIN_ACCESS_KEY=

# Optional: successful GitHub Actions run heartbeat endpoint.
# Configure this as the RADAR_HEARTBEAT_URL Actions secret in production.
RADAR_HEARTBEAT_URL=
