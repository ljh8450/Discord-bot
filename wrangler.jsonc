{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "discord-bot",
  "main": "cloudflare/radar-scheduler.mjs",
  "compatibility_date": "2026-07-20",
  "triggers": {
    "crons": [
      "2,12,22,32,42,52 * * * *",
      "5 0,9 * * *"
    ]
  },
  "observability": {
    "enabled": true
  }
}
